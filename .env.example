# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aishop

# ─── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-string

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Voyage AI (embeddings — voyage-3) ───────────────────────
VOYAGE_API_KEY=pa-...

# ─── Langfuse (monitoring) ───────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASEURL=https://cloud.langfuse.com

# ─── N8N (self-hosted) ───────────────────────────────────────
# URL where N8N is running
N8N_WEBHOOK_URL=http://localhost:5678
# Generate with: openssl rand -base64 64
# Must match the WEBHOOK_SECRET variable set inside N8N UI (Settings → Variables)
WEBHOOK_SECRET=change-me-to-a-long-random-string
# API key for NestJS → N8N internal calls (inventory endpoint)
# Generate with: openssl rand -base64 32
N8N_INTERNAL_API_KEY=change-me-to-a-long-random-string
# N8N webhook URLs (copy from N8N UI after importing workflows)
N8N_ORDER_STATUS_WEBHOOK_URL=http://localhost:5678/webhook/order-status-updates
N8N_COD_ORDER_WEBHOOK_URL=http://localhost:5678/webhook/cod-order-created
N8N_SUPPORT_ESCALATION_WEBHOOK_URL=http://localhost:5678/webhook/support-escalation

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Backend ─────────────────────────────────────────────────
PORT=3001
# Set to "production" before deploying
NODE_ENV=development
