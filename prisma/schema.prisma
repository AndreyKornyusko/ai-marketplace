generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

generator client_backend {
  provider      = "prisma-client-js"
  output        = "../backend/node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Product Domain ────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  sku         String   @unique
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  tags        String[]
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  variants      ProductVariant[]
  embedding     ProductEmbedding?
  orderItems    OrderItem[]
  reservations  InventoryReservation[]
  reviews       Review[]
  lowStockAlert LowStockAlert?

  @@index([category], map: "idx_products_category")
  @@index([isActive], map: "idx_products_is_active")
  @@map("products")
}

model ProductVariant {
  id         String  @id @default(uuid()) @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  value      String
  priceDelta Decimal @default(0) @db.Decimal(10, 2) @map("price_delta")
  stock      Int     @default(0)
  sku        String  @unique

  orderItems OrderItem[]

  @@map("product_variants")
}

model ProductEmbedding {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @unique @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  content   String
  // vector(1024) — voyage-3 dimensions; IVFFlat index created via raw migration
  embedding Unsupported("vector(1024)")?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_embeddings")
}

// ─── User Domain ───────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  SUPPORT
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  phone        String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  addresses UserAddress[]
  orders    Order[]
  tickets   SupportTicket[]
  reviews   Review[]

  @@map("users")
}

model UserAddress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?
  fullName  String   @map("full_name")
  phone     String?
  street    String
  city      String
  state     String
  zip       String
  country   String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "idx_user_addresses_user_id")
  @@map("user_addresses")
}

// ─── Order Domain ──────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  CARD
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String?       @map("user_id") @db.Uuid
  user          User?         @relation(fields: [userId], references: [id])
  guestEmail    String?       @map("guest_email")
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  subtotal      Decimal       @db.Decimal(10, 2)
  shippingTotal Decimal       @default(0) @db.Decimal(10, 2) @map("shipping_total")
  total         Decimal       @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  items        OrderItem[]
  reservations InventoryReservation[]
  tickets      SupportTicket[]

  @@index([userId], map: "idx_orders_user_id")
  @@index([status], map: "idx_orders_status")
  @@map("orders")
}

model OrderItem {
  id        String          @id @default(uuid()) @db.Uuid
  orderId   String          @map("order_id") @db.Uuid
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String          @map("product_id") @db.Uuid
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId String?         @map("variant_id") @db.Uuid
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2) @map("unit_price")
  total     Decimal         @db.Decimal(10, 2)

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

// ─── Inventory Domain ──────────────────────────────────────────────────────

enum ReservationStatus {
  ACTIVE
  COMMITTED
  RELEASED
}

model InventoryReservation {
  id        String            @id @default(uuid()) @db.Uuid
  productId String            @map("product_id") @db.Uuid
  product   Product           @relation(fields: [productId], references: [id])
  orderId   String?           @map("order_id") @db.Uuid
  order     Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  quantity  Int
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime          @map("expires_at")
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([productId, status], map: "idx_inventory_reservations_product_id")
  @@index([expiresAt], map: "idx_inventory_reservations_expires_at")
  @@map("inventory_reservations")
}

// ─── Review Domain ─────────────────────────────────────────────────────────

model Review {
  id           String   @id @default(uuid()) @db.Uuid
  productId    String   @map("product_id") @db.Uuid
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String?  @map("user_id") @db.Uuid
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  reviewerName String   @map("reviewer_name")
  rating       Int
  comment      String
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([productId], map: "idx_reviews_product_id")
  @@map("reviews")
}

// ─── AI / Embedding Domain ──────────────────────────────────────────────────

model PolicyEmbedding {
  id        String   @id @default(uuid()) @db.Uuid
  section   String   @db.VarChar(100) // shipping | returns | faq
  topic     String   @db.VarChar(255)
  content   String
  // vector(1024) — voyage-3 dimensions; IVFFlat index created via raw migration
  embedding Unsupported("vector(1024)")?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([section, topic], map: "policy_embeddings_section_topic_key")
  @@index([section], map: "idx_policy_embeddings_section")
  @@map("policy_embeddings")
}

// ─── Support Domain ────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

model SupportTicket {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String?      @map("user_id") @db.Uuid
  user             User?        @relation(fields: [userId], references: [id])
  guestEmail       String?      @map("guest_email")
  orderId          String?      @map("order_id") @db.Uuid
  order            Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  conversationId   String?      @map("conversation_id")
  subject          String
  status           TicketStatus @default(OPEN)
  escalationReason String?      @map("escalation_reason")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@map("support_tickets")
}

// ─── Monitoring Domain ─────────────────────────────────────────────────────

model LowStockAlert {
  productId String   @id @map("product_id") @db.Uuid
  product   Product  @relation(fields: [productId], references: [id])
  alertedAt DateTime @default(now()) @map("alerted_at")

  @@map("low_stock_alerts")
}
